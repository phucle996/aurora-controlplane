FROM golang:1.25-alpine

WORKDIR /app

RUN apk add --no-cache bash build-base git nodejs npm

COPY go.mod go.sum ./
RUN go mod download

COPY ui/package.json ui/package-lock.json ./ui/
RUN cd ui && npm ci

COPY . .

EXPOSE 8080 9090

CMD ["sh", "-c", "cd /app/ui && npm run build && exec go run ./cmd/server/main.go"]
