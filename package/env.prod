# ==========================================
# Control Plane Environment Variables
# ==========================================

# ------------------------------------------
# Application
# ------------------------------------------
APP_TIMEZONE="UTC"
APP_HTTP_PORT=8080
APP_LOG_LEVEL="info"

# ------------------------------------------
# Security
# ------------------------------------------
JWT_SECRET_KEY="f498b64b6938c30dbb4640dd67c1b97eb354cd22929434ce41d992ef968604bd"
OTT_SECRET="2e0ac173301f8dc2fe9ac10d887cbb2e46e40d2962de342c4713a82be9993c37"
REFRESH_SECRET="32b2d1414946f436783816e7a3b4e8f8f910800793dd08f83006ba5ba739c5f6"

# ------------------------------------------
# PostgreSQL Database
# ------------------------------------------
PSQL_HOST="localhost"
PSQL_PORT="15432"
PSQL_USER="postgres"
PSQL_PASSWORD="aurora-postgres"
PSQL_DBNAME="aurora"
PSQL_SSLMODE="verify-full"

# PostgreSQL TLS configuration
PSQL_TLS_ENABLED="true"
PSQL_TLS_CA="/etc/aurora-controlplane/tls/ca/ca.crt"
PSQL_TLS_CERT=""
PSQL_TLS_KEY=""

# PostgreSQL Connection Pool
PSQL_MAX_CONNS="20"
PSQL_MIN_CONNS="5"
PSQL_MAX_CONN_LIFE="30m"
PSQL_MAX_CONN_IDLE="5m"
PSQL_PING_TIMEOUT="5s"
PSQL_MAX_RETRIES="5"
PSQL_RETRY_INTERVAL="3s"

# ------------------------------------------
# Redis
# ------------------------------------------
REDIS_ADDR="localhost:16379"
REDIS_PASSWORD="aurora-redis"
REDIS_DB="0"

# Redis TLS configuration
REDIS_TLS_ENABLED="true"
REDIS_TLS_CA="/etc/aurora-controlplane/tls/ca/ca.crt"
REDIS_TLS_CERT=""
REDIS_TLS_KEY=""

# Redis Pool & Timeouts
REDIS_DIAL_TIMEOUT="5s"
REDIS_READ_TIMEOUT="3s"
REDIS_WRITE_TIMEOUT="3s"
REDIS_POOL_SIZE="20"
REDIS_MIN_IDLE_CONNS="5"
REDIS_PING_TIMEOUT="5s"
REDIS_MAX_RETRIES="5"
REDIS_RETRY_INTERVAL="3s"

# ------------------------------------------
# VictoriaMetrics
# ------------------------------------------
VICTORIA_WRITE_URL="http://localhost:18428/api/v1/write"
VICTORIA_READ_URL="http://localhost:18428/api/v1/query"
VICTORIA_USERNAME=""
VICTORIA_PASSWORD=""

# Victoria Timeouts
VICTORIA_WRITE_TIMEOUT="10s"
VICTORIA_READ_TIMEOUT="10s"
VICTORIA_PING_TIMEOUT="5s"
VICTORIA_MAX_RETRIES="3"
VICTORIA_RETRY_INTERVAL="2s"

# ------------------------------------------
# gRPC
# ------------------------------------------
GRPC_SERVER_PORT="9090"
GRPC_CLIENT_TLS_ENABLED="false"
GRPC_CLIENT_TLS_CA=""
GRPC_CLIENT_TLS_CERT=""
GRPC_CLIENT_TLS_KEY=""
