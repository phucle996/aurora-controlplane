# ==========================================
# Control Plane Environment Variables
# ==========================================

# ------------------------------------------
# Application
# ------------------------------------------
APP_TIMEZONE="UTC"
APP_HTTP_PORT=8080
APP_LOG_LEVEL="info"
APP_PUBLIC_URL="https://controlplane.example.com"

# ------------------------------------------
# Security
# ------------------------------------------
CORE_SECRET_MASTER_KEY="AZ2MGlGx8Bf3Yp3vmgNS2LPgdEYx2h4Wmlk+TkHBa9E="

# ------------------------------------------
# PostgreSQL Database
# ------------------------------------------
PSQL_HOST="localhost"
PSQL_PORT="5432"
PSQL_USER="postgres"
PSQL_PASSWORD="aurora-postgres"
PSQL_DBNAME="aurora"
PSQL_SSLMODE="verify-full"

# PostgreSQL TLS configuration
PSQL_TLS_ENABLED="true"
PSQL_TLS_CA="/etc/aurora-controlplane/tls/ca/ca.crt"
PSQL_TLS_CERT="/etc/aurora-controlplane/tls/postgres/client.crt"
PSQL_TLS_KEY="/etc/aurora-controlplane/tls/postgres/client.key"

# PostgreSQL Connection Pool
PSQL_MAX_CONNS="20"
PSQL_MIN_CONNS="5"
PSQL_MAX_CONN_LIFE="30m"
PSQL_MAX_CONN_IDLE="5m"
PSQL_PING_TIMEOUT="5s"
PSQL_MAX_RETRIES="5"
PSQL_RETRY_INTERVAL="3s"

# ------------------------------------------
# Redis
# ------------------------------------------
REDIS_ADDR="localhost:6379"
REDIS_PASSWORD="aurora-redis"
REDIS_DB="0"

# Redis TLS configuration
REDIS_TLS_ENABLED="true"
REDIS_TLS_CA="/etc/aurora-controlplane/tls/ca/ca.crt"
REDIS_TLS_CERT="/etc/aurora-controlplane/tls/redis/client.crt"
REDIS_TLS_KEY="/etc/aurora-controlplane/tls/redis/client.key"

# Redis Pool & Timeouts
REDIS_DIAL_TIMEOUT="5s"
REDIS_READ_TIMEOUT="3s"
REDIS_WRITE_TIMEOUT="3s"
REDIS_POOL_SIZE="20"
REDIS_MIN_IDLE_CONNS="5"
REDIS_PING_TIMEOUT="5s"
REDIS_MAX_RETRIES="5"
REDIS_RETRY_INTERVAL="3s"

# ------------------------------------------
# VictoriaMetrics
# ------------------------------------------
VICTORIA_WRITE_URL="http://localhost:8428/api/v1/write"
VICTORIA_READ_URL="http://localhost:8428/api/v1/query"
VICTORIA_USERNAME=""
VICTORIA_PASSWORD=""

# Victoria Timeouts
VICTORIA_WRITE_TIMEOUT="10s"
VICTORIA_READ_TIMEOUT="10s"
VICTORIA_PING_TIMEOUT="5s"
VICTORIA_MAX_RETRIES="3"
VICTORIA_RETRY_INTERVAL="2s"

# ------------------------------------------
# gRPC
# ------------------------------------------
GRPC_SERVER_PORT="9090"
GRPC_SERVER_TLS_ENABLED="true"
GRPC_SERVER_TLS_CERT="/etc/aurora-controlplane/tls/grpc/server.crt"
GRPC_SERVER_TLS_KEY="/etc/aurora-controlplane/tls/grpc/server.key"
GRPC_DATAPLANE_CLIENT_CA="/etc/aurora-controlplane/tls/ca/ca.crt"
GRPC_DATAPLANE_CLIENT_CA_KEY="/etc/aurora-controlplane/tls/ca/ca.key"
GRPC_DATAPLANE_ENROLL_TOKEN="d0495cf018ffad5a7740e1364fb75abcef804d7169c53111d42caaf0b2e04df8"
GRPC_DATAPLANE_CLIENT_CERT_TTL="720h"
GRPC_DATAPLANE_HEARTBEAT_INTERVAL="30s"
GRPC_DATAPLANE_STALE_TIMEOUT="2m"
GRPC_CLIENT_TLS_ENABLED="false"
GRPC_CLIENT_TLS_CA=""
GRPC_CLIENT_TLS_CERT=""
GRPC_CLIENT_TLS_KEY=""
